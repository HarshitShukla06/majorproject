# MongoDB Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority

# JWT Secret Key (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Server Port
PORT=5000

# Frontend URLs (comma-separated for production)
# Format: http://localhost:5173,https://your-netlify-domain.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Node Environment
NODE_ENV=development
